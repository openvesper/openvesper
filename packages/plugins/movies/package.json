  },
  "keywords": [
    "openvesper",
    "plugin",
    "movies",
    "ai",
    "agent"
  ],
  "author": "OpenVesper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openvesper/openvesper.git",
    "directory": "packages/plugins/movies"
  },
  "homepage": "https://github.com/openvesper/openvesper/tree/main/packages/plugins/movies",
  "bugs": "https://github.com/openvesper/openvesper/issues",
  "engines": {
    "node": ">=18"
  }
}
