{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔨 Build All",
      "type": "shell",
      "command": "pnpm build",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "🧪 Test",
      "type": "shell",
      "command": "pnpm test",
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "🌒 Run CLI",
      "type": "shell",
      "command": "pnpm --filter=@openvesper/cli dev"
    },
    {
      "label": "🌐 Run Website",
      "type": "shell",
      "command": "cd apps/website && npm run dev"
    }
  ]
}
