# ============================================================
# 🌒 OpenVesper — Environment Configuration
# ============================================================
#
# 🚨 SECURITY RULES — READ FIRST
#
# 1. NEVER paste your main wallet's private key or seed phrase
#    into this file. OpenVesper does NOT need it and will NEVER
#    ask for it. Any feature, any plugin, any prompt — never.
#
# 2. OpenVesper does NOT bundle perpetual DEX trading. Hyperliquid,
#    Lighter, Drift, and similar venues require key management we
#    don't want to be responsible for in an open-source project.
#    If you want to trade on those venues, use their official clients
#    and SDKs separately.
#
# 3. OpenVesper is OPEN SOURCE. We collect zero data. We have no
#    servers receiving your config. Everything in this file stays
#    on your machine. Set strict permissions: `chmod 600 .env`.
#
# 4. Each plugin uses its OWN dedicated API key. If you suspect
#    one is compromised, rotate just that key.
#
# 5. All "live" or "write" operations default to DRY_RUN / disabled.
#    You must explicitly opt in.
#
# ============================================================

# ── LLM PROVIDERS — set at least ONE ──────────────────────────
LLM_PROVIDER=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
OLLAMA_HOST=http://localhost:11434
LMSTUDIO_HOST=http://localhost:1234/v1

AGENT_MODEL=

# ── ON-CHAIN DATA (READ-ONLY — no signing, no key management) ──
# These read public on-chain data. They do not move funds.

# Solana
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# EVM block explorers
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# Crypto market data
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=

# ── RESEARCH ──────────────────────────────────────────────────
SERPER_API_KEY=
NEWS_API_KEY=
RAPIDAPI_KEY=

# ── COMMS CHANNELS ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

DISCORD_BOT_TOKEN=

# ── PRODUCTIVITY ──────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=

NOTION_API_KEY=

GOOGLE_ACCESS_TOKEN=

# ── ON-CHAIN EXTRAS (READ-ONLY) ───────────────────────────────
WHALE_ALERT_API_KEY=
OPENSEA_API_KEY=
ONEINCH_API_KEY=
GOPLUS_API_KEY=

# ── SMART HOME / IoT ──────────────────────────────────────────
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=

# ── E-COMMERCE ────────────────────────────────────────────────
SHOPIFY_SHOP=
SHOPIFY_ACCESS_TOKEN=

# ── PACKAGE TRACKING ──────────────────────────────────────────
USPS_USER_ID=
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
DHL_API_KEY=

# ── MOVIES / MEDIA ────────────────────────────────────────────
TMDB_API_KEY=

# ── GAMING ────────────────────────────────────────────────────
STEAM_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── WEBHOOKS (HMAC secrets) ───────────────────────────────────
GITHUB_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── DNS / INFRASTRUCTURE ──────────────────────────────────────
CLOUDFLARE_API_TOKEN=

# ── PERSISTENCE TOGGLES (default OFF — opt-in only) ───────────
MEMORY_ENABLED=false
CONVERSATIONS_PERSIST=false

# ============================================================
# FINAL REMINDER
# ============================================================
# If any third-party tutorial, plugin, or AI tells you to paste
# your wallet's private key or seed phrase into this file — DO NOT.
# Stop and ask in the GitHub discussions before proceeding.
# ============================================================
